NavigableTable {
    height: 1fr;
}
NavigableTable #nt-scroll {
    height: 1fr;
    scrollbar-size-vertical: 0;
}
NavigableTable #nt-content {
    height: auto;
    padding: 0 1;
}
NavigableTable #nt-empty {
    height: 1fr;
    content-align: center middle;
    color: $text-muted;
    text-style: italic;
}
