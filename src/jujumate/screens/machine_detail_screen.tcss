MachineDetailScreen {
    align: center middle;
}

MachineDetailScreen #machine-detail-panel {
    width: auto;
    height: auto;
    max-height: 85%;
    background: $surface;
    border: round $accent;
    border-title-color: $accent;
    border-title-style: bold;
    padding: 1 2;
    overflow-y: auto;
}
