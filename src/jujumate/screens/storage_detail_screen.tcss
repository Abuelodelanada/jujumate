StorageDetailScreen {
    align: center middle;
}

StorageDetailScreen #storage-detail-panel {
    width: 75%;
    height: auto;
    max-height: 85%;
    background: $surface;
    border: round $accent;
    border-title-color: $accent;
    border-title-style: bold;
    padding: 1 2;
    overflow-y: auto;
}
